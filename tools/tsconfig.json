{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "../dist-tools",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["."],
  "exclude": ["node_modules"],
  "references": [
    { "path": ".." }
  ]
}
